# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL = '₹'

# Vendor AI Insights (replaceable provider: gemini | openai)
AI_INSIGHTS_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# When using openai:
# AI_INSIGHTS_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Ask AI feature: Groq (primary) + Gemini (fallback when limit reached) ---
# Get Groq key: https://console.groq.com | Gemini key: https://aistudio.google.com/apikey
ASK_AI_GROQ_API_KEY=
# Optional: Serper (https://serper.dev) for electronics Ask AI—web search for specs/product context
SERPER_API_KEY=
# Backup keys: used in round-robin with primary so load is spread evenly (same model for all Groq keys)
ASK_AI_GROQ_MODEL=llama-3.3-70b-versatile
ASK_AI_GROQ_API_KEY_BACKUP=
ASK_AI_GROQ_API_KEY_BACKUP_2=
ASK_AI_GROQ_API_KEY_BACKUP_3=
ASK_AI_GROQ_API_KEY_BACKUP_4=
ASK_AI_GROQ_API_KEY_BACKUP_5=
ASK_AI_GROQ_API_KEY_BACKUP_6=
ASK_AI_GROQ_API_KEY_BACKUP_7=
ASK_AI_GROQ_API_KEY_BACKUP_8=
ASK_AI_GEMINI_API_KEY=
ASK_AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
ASK_AI_GEMINI_MODEL=gemini-2.0-flash
SERPER_API_KEY_BACKUP=
# OpenCage (free tier: https://opencagedata.com) for address/location picker reverse geocoding
OPENCAGE_API_KEY=
